{
  "$schema": "https://opencode.ai/config.json",
  "username": "Serhii",
  "autoupdate": true,
  "agent": {
    "example": {
      "disable": true
    },
    "build": {
      "mode": "primary",
      "temperature": 0.1
    },
    "plan": {
      "mode": "primary",
      "temperature": 0.1
    }
  },
  "permission": {
    "bash": {
      "*": "deny",
      "~/projects/**": "ask",
      "~/.config/opencode/**": "ask",
      "echo *": "allow",
      "pwd": "allow",
      "ls *": "allow",
      "git status *": "allow",
      "git add *": "allow",
      "git commit *": "allow"
    },
    "read": {
      "*": "deny",
      "~/projects/**": "allow",
      "~/.config/opencode/**": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "write": {
      "*": "deny",
      "~/projects/**": "allow",
      "~/.config/opencode/**": "allow"
    },
    "edit": {
      "*": "deny",
      "~/projects/**": "allow",
      "~/.config/opencode/**": "allow"
    },
    "list": {
      "*": "deny",
      "~/projects/**": "allow",
      "~/.config/opencode/**": "allow"
    },
    "glob": {
      "*": "deny",
      "~/projects/**": "allow",
      "~/.config/opencode/**": "allow"
    },
    "grep": {
      "*": "deny",
      "~/projects/**": "allow",
      "~/.config/opencode/**": "allow"
    },
    "external_directory": {
      "*": "deny",
      "~/projects/**": "allow",
      "~/.config/opencode/**": "allow"
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      ".idea/**"
    ]
  },
