{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "default_agent": "plan",

  // https://opencode.ai/docs/ru/config#models
  "model": "{env:OPENCODE_MODEL}",
  "provider": {
    "anthropic": {
      "models": {},
      "options": {
        "apiKey": "{env:API_KEY_ZEN}"
      }
    }
  },

  // https://opencode.ai/docs/ru/config#инструменты
  "tools": {
    "write": false,
    "bash": false
  },

  // https://opencode.ai/docs/ru/config#сервер
  "server": {
    "port": 9999,
    "hostname": "0.0.0.0",
    "mdns": true,
    "mdnsDomain": "opencode.local",
    "cors": ["http://localhost:9999"]
  },

  // https://opencode.ai/docs/ru/config#permission
  "permission": {
    "*":"deny",

    "read": { "~/projects/*": "allow" },
    "edit": { "~/projects/*": "allow" },
    "list": { "~/projects/*": "allow" },
    "glob": { "~/projects/*": "allow" },
    "grep": { "~/projects/*": "allow" },
    "external_directory": { "~/projects/*": "allow" }
  },

  // https://opencode.ai/docs/ru/config#watcher
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", ".idea/**"]
  },

  // TODO
  // https://opencode.ai/docs/ru/config#плагины
  "plugin": []

  // https://opencode.ai/docs/ru/config#enabled_providers
//  "enabled_providers": ["anthropic", "openai"],
}
