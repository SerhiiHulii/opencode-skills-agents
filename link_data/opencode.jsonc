{
  "$schema": "https://opencode.ai/config.json",
  "username": "Serhii",
  "autoupdate": true,
  "default_agent": "plan",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "{env:OPENCODE_MODEL}",
      "temperature": 0.1,
      "permission": "ask",
      "tools": { "write": true, "edit": true, "bash": true }
    },
    "plan": {
      "mode": "primary",
      "model": "{env:OPENCODE_MODEL}",
      "temperature": 0.1,
      "permission": "ask",
      "tools": { "write": false, "edit": false, "bash": false }
    }
  },

  // https://opencode.ai/docs/ru/config#models
  "model": "{env.OPENCODE_MODEL}",
  "provider": {
    // Zen models pricing https://opencode.ai/docs/zen/
    // List of providers https://models.dev/
    "opencode": {
      "models": { "big-pickle": { "name": "BigPickle" } },
      "options": { "apiKey": "{env:API_KEY_ZEN}" }
    },
    "opencode-go": {
      // List of zen models https://opencode.ai/zen/v1/models
      "models": { "glm-5": { "name": "GLM-5" } },
      "options": { "apiKey": "{env:API_KEY_ZEN}" }
    }
  },

  // https://opencode.ai/docs/ru/config#permission
  "permission": {
    // patch - Этот инструмент применяет файлы исправлений к вашей кодовой базе.
    // todowrite - Создает и обновляет списки задач для отслеживания прогресса во время сложных операций.
    // webfetch - Позволяет LLM получать и читать веб-страницы. Полезно для поиска документации или исследований.
    // question - Этот инструмент позволяет LLM задавать вопросы пользователю во время выполнения задачи.
    // "allow" — запуск без одобрения, "ask" — запрос на одобрение, "deny" — заблокировать действие
    "*":"deny",

    // bash - Этот инструмент позволяет LLM запускать команды терминала, такие как npm install, git status, ...
    "bash": { "~/projects/*": "ask", "~/.config/opencode/*": "ask" },

    // read - Этот инструмент читает файлы и возвращает их содержимое.
    "read": {
      "~/projects/*": "allow",
      "~/.config/opencode/*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },

    // write - Используйте это, чтобы позволить LLM создавать новые файлы или перезаписывайте существующие.
    "write": { "~/projects/*": "allow", "~/.config/opencode/*": "allow" },

    // edit - Этот инструмент выполняет точное редактирование файлов, заменяя точные совпадения текста.
    "edit": { "~/projects/*": "allow", "~/.config/opencode/*": "allow" },

    // list - Этот инструмент отображает содержимое каталога.
    "list": { "~/projects/*": "allow", "~/.config/opencode/*": "allow" },

    // glob - Ищите файлы, используя шаблоны glob, например **/*.js или src/**/*.ts.
    "glob": { "~/projects/*": "allow", "~/.config/opencode/*": "allow" },

    // grep - Поиск содержимого файла с помощью регулярных выражений.
    "grep": { "~/projects/*": "allow", "~/.config/opencode/*": "allow" },

    "external_directory": { "~/projects/*": "allow", "~/.config/opencode/*": "allow" }
  },

  // https://opencode.ai/docs/ru/config#watcher
  "watcher": { "ignore": ["node_modules/**", "dist/**", ".git/**", ".idea/**"] },

  // https://opencode.ai/docs/ru/config#%D0%BF%D0%BB%D0%B0%D0%B3%D0%B8%D0%BD%D1%8B
  // https://opencode.ai/docs/ecosystem#plugins
  "plugin": ["@mohak34/opencode-notifier@latest"],

  // https://opencode.ai/docs/ru/config#enabled_providers
  "enabled_providers": ["anthropic", "openai", "gemini", "google", "github-copilot", "opencode", "opencode-go"]
}
